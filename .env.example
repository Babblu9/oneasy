# Vercel AI Gateway API Key
# Get yours from: https://vercel.com/dashboard → AI Gateway
AI_GATEWAY_API_KEY=your_api_key_here

# OpenAI-compatible Vercel AI Gateway base URL (used automatically by the app)
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional: Change the model (default: anthropic/claude-sonnet-4-5)
# Supports any model from Vercel AI Gateway: openai/gpt-4o, anthropic/claude-sonnet-4-5, google/gemini-2.0-flash, etc.
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-5
